{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Lancer Mon Générateur PFA",
            "program": "${workspaceFolder}/node_modules/yo/lib/cli.js",
            "args": [
                "./generators/app" 
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
